PORT=4000
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174
JWT_SECRET=sentinelx-dev-secret-change-me
JWT_EXPIRES_IN=8h

# Firebase Authentication + Realtime Database (optional — leave blank to run
# on the legacy mock-JWT demo accounts instead). No service account required.
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_URL=

# OpenRouter — powers the real "AI Threat Analyst" insight. Optional; the
# simulation runs fine without it, just without the LLM-generated insight card.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
