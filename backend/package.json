{
  "name": "sentinelx-backend",
  "version": "0.1.0",
  "description": "SentinelX AI - National Fraud Intelligence Platform backend (mock intelligence engine, REST APIs, Socket.IO gateway)",
  "private": true,
  "type": "module",
  "main": "dist/backend/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/backend/src/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jose": "^6.2.4",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/uuid": "^9.0.8",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
